# Load order (see app.js): 1) this file  2) gitignored `.env` (override: true, local only)
#
# --- Heroku (웹): PC .env는 배포되지 않음. Dashboard → Settings → Config Vars ---
#   필수(에이전트): AI_API_KEY, E2B_API_KEY
#   권장(기본과 동일): AI_ENDPOINT, AI_MODEL (아래 공개 기본값과 같으면 생략 가능)
#   3D: CESIUM_ION_ACCESS_TOKEN

PORT=3000
TRUST_PROXY=
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=orbit

SESSION_SECRET=dev-only-replace-in-dot-env-for-real-secret
SESSION_COOKIE_SECURE=false

CESIUM_ION_ACCESS_TOKEN=

# 공개 기본값 — 비밀 아님. Heroku에서 덮어쓰려면 같은 이름으로 Config Var 설정.
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-5.4-mini
AI_TIMEOUT_MS=20000

# 비밀 키는 이 파일에 적지 말 것. 로컬은 `.env`, Heroku는 Config Vars.
# AI_API_KEY=

PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRO_CURRENCY=USD
PAYPAL_PRO_PRICE=10.00

E2B_API_KEY=
