# Copy to `.env` (never commit `.env`).

# ── MongoDB (Atlas: paste connection string) ─────────────────────────────
# Either name works; if both are unset, defaults to mongodb://127.0.0.1:27017
MONGODB_URI=
# MONGODB_URL=
MONGODB_DB_NAME=orbit

# ── Sessions (required when NODE_ENV=production) ───────────────────────
SESSION_SECRET=

# ── Public URL (SEO: canonical, Open Graph, sitemap) ───────────────────
# No trailing slash. Example: https://orbit-hnr.com
# PUBLIC_SITE_URL=

# ── Server ──────────────────────────────────────────────────────────────
# PORT=3000
# NODE_ENV=production

# ── PayPal (billing) ───────────────────────────────────────────────────
# PAYPAL_ENV=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_PRO_CURRENCY=USD
# PAYPAL_PRO_PRICE=10.00

# ── AI agent (single stack; never commit keys)
# AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
# AI_TIMEOUT_MS=20000

# ── E2B sandbox (agent Python) ─────────────────────────────────────────
E2B_API_KEY=

# ── Cesium Ion (tracker globe) ─────────────────────────────────────────
# CESIUM_ION_ACCESS_TOKEN=

# Optional: point E2B or tooling at a specific parsed JSON (leave empty if unused)
# PARSED_JSON_PATH=data/users/USER_OBJECT_ID/parsed/your-flight.json
