# Copy to `.env` (never commit `.env`). `npm run start:prod` / `node app.js` loads this via dotenv.

# --- Server ---
PORT=3000
# Behind nginx/Render/etc. set to 1 or true so secure cookies / client IP work correctly
# TRUST_PROXY=1
NODE_ENV=development

# --- MongoDB (app data + session store) ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=orbit
# Optional: collection name for express-session (default: sessions)
# MONGODB_SESSION_COLLECTION=sessions

# --- Sessions (required in production) ---
# Generate e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=
# For HTTPS deployments: SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SECURE=false
# SESSION_MAX_AGE_MS=604800000
# SESSION_COOKIE_SAMESITE=lax

# --- PayPal billing ---
# PAYPAL_ENV=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_PRO_CURRENCY=USD
# PAYPAL_PRO_PRICE=10.00

# --- AI / agent (optional) ---
# AI_API_KEY=
# AI_ENDPOINT=
# AI_FREE_MODEL=
# AI_PRO_MODEL=
# CESIUM_ION_ACCESS_TOKEN=

# --- E2B sandbox (`logic/aiAgent/e2b-chat.cjs`) ---
E2B_API_KEY=

# Optional: point E2B or tooling at a specific parsed JSON (leave empty if unused)
# PARSED_JSON_PATH=data/users/USER_OBJECT_ID/parsed/your-flight.json
