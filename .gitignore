# Dependencies
node_modules/

# Runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
config/ai-agent.local.js
config/cesium-ion.local.js

# Per-user workspace (flight files, parsed JSON, chat JSON, profile images)
data/users/**
!data/users/.gitkeep

# Legacy per-user storage (existing installs)
uploads/avatars/*
!uploads/avatars/.gitkeep
data/storage/raw_uploads/**
!data/storage/raw_uploads/.gitkeep
data/storage/parsed_json/**
!data/storage/parsed_json/.gitkeep

# Python cache / virtual env
__pycache__/
*.py[cod]
.venv/
venv/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.bak
*.tmp

# OS files
.DS_Store
Thumbs.db
