<!DOCTYPE html>
<html lang="en">
  <%- include("../shared/head", { pageTitle: "Rocket Tracker | Sign Up" }) %>
  <body>
    <%- include("../shared/header") %>
    <main class="container auth-layout">
      <section class="auth-card">
        <h1>Create Account</h1>
        <% if (sessionData.errorMessage) { %>
          <p class="message message-error"><%= sessionData.errorMessage %></p>
        <% } %>
        <form action="/signup" method="POST" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required value="<%= sessionData.email %>" />
          <label for="password">Password</label>
          <input id="password" type="password" name="password" required />
          <label for="confirm-password">Confirm Password</label>
          <input id="confirm-password" type="password" name="confirm-password" required value="<%= sessionData.confirmPassword || '' %>" />
          <p class="auth-switch">Nickname is auto-generated and can be changed later in profile settings.</p>
          <button type="submit" class="button button-primary">Sign Up</button>
        </form>
      </section>
    </main>
  </body>
</html>
