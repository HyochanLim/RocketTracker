<div class="tracker-agent-panel">
  <div class="tracker-agent-topchips" aria-label="Plan and model">
    <% if (!(typeof isPro !== "undefined" && isPro)) { %>
      <a class="tracker-agent-pro-hint" href="/pricing" aria-label="Upgrade to Pro to enable charts">
        Charts & images require Pro
      </a>
    <% } %>
    <div class="tracker-agent-meta">
      <span class="tracker-agent-meta-tier <%= typeof isPro !== 'undefined' && isPro ? 'is-pro' : '' %>">
        <%= typeof aiTierLabel !== "undefined" ? aiTierLabel : "" %>
      </span>
      <span class="tracker-agent-meta-model"><%= typeof aiModelLabel !== "undefined" ? aiModelLabel : "" %></span>
    </div>
  </div>
  <div class="tracker-agent-thread" id="tracker-agent-thread" role="log" aria-live="polite">
    <div class="tracker-agent-welcome" id="tracker-agent-welcome">
      <p class="tracker-agent-welcome-title">Flight assistant</p>
      <p class="tracker-agent-welcome-text">
        Chat casually, or ask about your flight—run Analyze on a file so answers match your data.
      </p>
    </div>
    <div class="tracker-agent-messages" id="tracker-agent-messages" hidden></div>
  </div>
  <div class="tracker-agent-composer">
    <label class="tracker-agent-sr-only" for="tracker-agent-input">Message</label>
    <div class="tracker-agent-composer-row">
      <textarea
        id="tracker-agent-input"
        class="tracker-agent-input"
        rows="1"
        placeholder="Type a message…"
        autocomplete="off"
      ></textarea>
      <button
        type="button"
        class="tracker-agent-send"
        id="tracker-agent-send"
        disabled
        aria-label="Send message"
      >
        <svg
          class="tracker-agent-send-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"
          />
        </svg>
      </button>
    </div>
  </div>
</div>
