<!DOCTYPE html>
<html lang="en">
  <%- include("../shared/head", { pageTitle: "Rocket Tracker | Tracker", extraStyles: [
    "/public/styles/tracker.css",
    "https://cesium.com/downloads/cesiumjs/releases/1.139.1/Build/Cesium/Widgets/widgets.css",
  ] }) %>
  <body>
    <%- include("../shared/header") %>
    <main class="container page-panel tracker-panel">
      <div class="tracker-page">
        <% if (message && message.text) { %>
          <p class="message <%= message.type === 'error' ? 'message-error' : 'message-success' %>">
            <%= message.text %>
          </p>
        <% } %>
        <div id="trackerInputSection">
          <input type="hidden" id="tracker-csrf-token" value="<%= csrfToken %>" />
          <div class="tracker-upload-form">
            <label for="tracker-upload-file">Upload New Flight File</label>
            <div class="tracker-upload-input-row">
              <input id="tracker-upload-file" class="tracker-upload-input" type="file" accept=".json,.csv,.xls,.xlsx" />
              <button type="button" id="clear-upload-file-button" class="button button-ghost">Clear</button>
            </div>
          </div>

          <section class="tracker-saved-section">
            <h2 class="tracker-saved-title">Saved Flight Files</h2>
            <p id="tracker-empty-text" class="profile-description <%= files && files.length > 0 ? 'tracker-hidden-section' : '' %>">
              No saved files yet.
            </p>
            <div id="tracker-saved-controls" class="<%= files && files.length > 0 ? '' : 'tracker-hidden-section' %>">
              <div id="tracker-saved-list" class="tracker-saved-list">
                <% files.forEach(function (f) { %>
                  <div class="tracker-saved-item" data-file-id="<%= f._id %>">
                    <span class="tracker-saved-item-label"><strong><%= f.originalName %></strong></span>
                    <button
                      type="button"
                      class="button button-ghost tracker-saved-delete"
                      data-file-id="<%= f._id %>"
                      aria-label="Delete saved flight file"
                    >
                      Delete
                    </button>
                  </div>
                <% }) %>
              </div>
            </div>
          </section>

          <div id="tracker-warning" class="tracker-warning tracker-hidden-section" role="alert" aria-live="polite"></div>

          <div class="tracker-analyze-wrap" id="tracker-analyze-wrap" hidden>
            <button type="button" id="showVisualizerButton" class="button button-secondary">Analyze</button>
          </div>
        </div>

        <div
          id="tracker-analyze-loading"
          class="tracker-analyze-loading tracker-hidden-section"
          role="status"
          aria-live="polite"
          aria-hidden="true"
        >
          <div class="tracker-analyze-loading-inner">
            <div class="tracker-analyze-spinner" aria-hidden="true"></div>
            <p id="tracker-analyze-loading-text" class="tracker-analyze-loading-text">Preparing analysis…</p>
          </div>
        </div>

        <section id="trackerVisualizerSection" class="tracker-visualizer-section tracker-hidden-section">
          <div id="cesiumContainer" class="tracker-visualizer-root"></div>
          <div class="tracker-visualizer-back-row">
            <button id="backToUploadButton" class="button button-ghost" type="button">Back</button>
          </div>
        </section>
      </div>

      <script src="/public/scripts/tracker-page.js"></script>
      <script src="https://cesium.com/downloads/cesiumjs/releases/1.139.1/Build/Cesium/Cesium.js"></script>
      <script type="application/json" id="cesium-ion-token-json"><%- JSON.stringify(typeof cesiumIonToken !== "undefined" ? cesiumIonToken : "") %></script>
      <script src="/logic/3Dvisualizer/cesium-viewer.js"></script>
      <script src="/logic/3Dvisualizer/cesium.trajectory.js"></script>
      <script src="/logic/3Dvisualizer/trajectory.js"></script>
      <script src="/logic/3Dvisualizer/cesium.visual.js"></script>
    </main>
  </body>
</html>
