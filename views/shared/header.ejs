<header class="site-header">
  <% const safeIsAuth = typeof isAuth === "undefined" ? false : isAuth; %>
  <% const safeUser = typeof user === "undefined" || !user ? { id: "", displayName: "User", imageUrl: "" } : user; %>
  <nav class="navbar container" aria-label="Primary">
    <a
      href="/"
      class="brand brand--orbit"
      aria-label="Orbit home"
      draggable="false"
      oncontextmenu="return false;"
      ondragstart="return false;"
    >
      <%- include("orbit-brand-img", { orbitBrandImgClass: "orbit-brand-img--nav" }) %>
    </a>
    <ul class="nav-primary">
      <li><a href="/products">Products</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/resources">Resources</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="nav-actions">
      <ul class="nav-links nav-links--actions">
        <% if (!safeIsAuth) { %>
          <li><a href="/login" class="nav-link-muted">Log in</a></li>
          <li><a href="/signup" class="button button-primary nav-cta">Sign up</a></li>
        <% } else { %>
          <li>
            <a href="/profile/<%= safeUser.id || '' %>" class="profile-trigger" aria-label="Go to profile">
              <span class="profile-avatar-wrap" aria-hidden="true">
                <img
                  class="profile-avatar"
                  src="<%= safeUser.imageUrl || '' %>"
                  alt="Profile avatar"
                />
              </span>
              <span class="profile-name"><%= safeUser.displayName || "User" %></span>
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </nav>
</header>
