<header class="site-header">
  <% const safeIsAuth = typeof isAuth === "undefined" ? false : isAuth; %>
  <% const safeUser = typeof user === "undefined" || !user ? { id: "", displayName: "User", imageUrl: "" } : user; %>
  <nav class="navbar container">
    <a href="/" class="brand">Rocket Tracker</a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/about">About</a></li>
      <% if (!safeIsAuth) { %>
        <li><a href="/login" class="button button-ghost">Login</a></li>
        <li><a href="/signup" class="button button-ghost">Sign Up</a></li>
      <% } else { %>
        <li><a href="/tracker">Tracker</a></li>
        <li>
          <form action="/logout" method="POST" class="nav-inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="button button-ghost">Logout</button>
          </form>
        </li>
        <li>
          <a href="/profile/<%= safeUser.id || '' %>" class="profile-trigger" aria-label="Go to profile">
            <span class="profile-avatar-wrap" aria-hidden="true">
              <img
                class="profile-avatar"
                src="<%= safeUser.imageUrl || '' %>"
                alt="Profile avatar"
              />
            </span>
            <span class="profile-name"><%= safeUser.displayName || "User" %></span>
          </a>
        </li>
      <% } %>
    </ul>
  </nav>
</header>
