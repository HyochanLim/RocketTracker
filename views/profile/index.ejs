<!DOCTYPE html>
<html lang="en">
  <%- include("../shared/head", {
    pageTitle: "Orbit | Profile",
    metaDescription: "Manage your Orbit profile, avatar, and bio.",
    metaRobots: "noindex, nofollow"
  }) %>
  <body>
    <%- include("../shared/header") %>
    <main class="container auth-layout">
      <section class="auth-card auth-card-profile">
        <header class="profile-page-header">
          <h1>Profile</h1>
          <p class="profile-lead">Avatar, name, and bio. Edit anytime.</p>
        </header>

        <% if (message && message.text) { %>
          <p id="profile-message" class="message <%= message.type === 'error' ? 'message-error' : 'message-success' %>">
            <%= message.text %>
          </p>
        <% } else { %>
          <p id="profile-message" class="message" hidden></p>
        <% } %>

        <div class="profile-identity">
          <div class="profile-avatar-ring">
            <img
              id="profile-avatar-preview"
              class="profile-avatar-lg"
              src="<%= userData.imageUrl || '' %>"
              alt=""
            />
          </div>
          <div class="profile-identity-main">
            <p class="profile-display-name"><%= userData.displayName || "User" %></p>
            <% if (Array.isArray(userData.badgeDefs) && userData.badgeDefs.length > 0) { %>
              <div class="profile-badges" aria-label="Badges">
                <% userData.badgeDefs.forEach(function (b) { %>
                  <span class="profile-badge" title="<%= b.description || b.label %>">
                    <img class="profile-badge-icon" src="<%= b.svgHref %>" alt="<%= b.label %> badge" />
                    <span class="profile-badge-label"><%= b.label %></span>
                  </span>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <section class="profile-about" aria-labelledby="profile-about-label">
          <h2 id="profile-about-label" class="profile-about-label">About</h2>
          <p
            id="profile-bio-summary"
            class="profile-bio-body<%= userData.bio && String(userData.bio).trim() ? '' : ' profile-bio-empty' %>"
          >
            <%= userData.bio && String(userData.bio).trim() ? userData.bio : "No bio yet — open Edit Profile to write one." %>
          </p>
        </section>

        <div class="profile-action-row">
          <button type="button" id="toggle-profile-edit" class="button button-secondary">
            <%= showEditForm ? "Close Edit" : "Edit Profile" %>
          </button>
          <form action="/logout" method="POST" class="logout-inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="button button-danger">Logout</button>
          </form>
        </div>

        <form
          action="/profile/<%= userData.id || '' %>"
          method="POST"
          class="form-grid profile-edit-form"
          enctype="multipart/form-data"
          style="<%= showEditForm ? '' : 'display:none;' %>"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label for="display-name">Display Name</label>
          <input
            id="display-name"
            type="text"
            name="display-name"
            required
            value="<%= userData.displayName || '' %>"
          />

          <label for="email">Email</label>
          <p id="email" class="profile-readonly-field"><%= userData.email || "" %></p>

          <label for="avatar-image">Avatar Image (png/jpg/gif/webp)</label>
          <input id="avatar-image" type="file" name="avatar-image" accept=".png,.jpg,.jpeg,.gif,.webp,image/png,image/jpeg,image/gif,image/webp" />
          <p id="avatar-file-name" class="profile-file-help">No file selected.</p>

          <label for="bio">Bio</label>
          <textarea
            id="bio"
            name="bio"
            rows="4"
            maxlength="1200"
            placeholder="Write a short bio..."
          ><%= userData.bio || "" %></textarea>

          <button type="submit" class="button button-primary">Save Profile</button>
        </form>

        <script>
          (function () {
            var toggleButton = document.getElementById("toggle-profile-edit");
            var form = document.querySelector(".profile-edit-form");
            var message = document.getElementById("profile-message");
            var avatarPreview = document.getElementById("profile-avatar-preview");
            var avatarInput = document.getElementById("avatar-image");
            var avatarFileName = document.getElementById("avatar-file-name");
            if (!toggleButton || !form) return;

            toggleButton.addEventListener("click", function () {
              var opening = form.style.display === "none";
              if (opening) {
                form.style.display = "grid";
                toggleButton.textContent = "Close Edit";
              } else {
                form.style.display = "none";
                toggleButton.textContent = "Edit Profile";
              }
            });

            if (avatarInput && avatarFileName) {
              avatarInput.addEventListener("change", function () {
                var file = avatarInput.files && avatarInput.files[0];
                avatarFileName.textContent = file ? file.name : "No file selected.";
              });
            }

            form.addEventListener("submit", async function (event) {
              event.preventDefault();

              var formData = new FormData(form);
              var csrfInput = form.querySelector('input[name="_csrf"]');
              var csrfToken = csrfInput ? csrfInput.value : "";
              var submitButton = form.querySelector('button[type="submit"]');
              var originalSubmitText = submitButton ? submitButton.textContent : "";
              if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = "Saving...";
              }
              try {
                var response = await fetch(form.action, {
                  method: "POST",
                  headers: {
                    "X-Requested-With": "XMLHttpRequest",
                    "CSRF-Token": csrfToken,
                  },
                  body: formData,
                });
                var contentType = response.headers.get("content-type") || "";
                var data;
                if (contentType.includes("application/json")) {
                  data = await response.json();
                } else {
                  var text = await response.text();
                  throw new Error(text || "Unexpected server response.");
                }

                if (!response.ok || !data.ok) {
                  message.hidden = false;
                  message.className = "message message-error";
                  message.textContent = data.message || "Failed to update profile.";
                  form.style.display = "grid";
                  toggleButton.textContent = "Close Edit";
                  if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.textContent = originalSubmitText;
                  }
                  return;
                }

                if (data.user.imageUrl) avatarPreview.src = data.user.imageUrl;
                var displayNameEl = document.querySelector(".profile-display-name");
                if (displayNameEl && typeof data.user.displayName === "string") {
                  displayNameEl.textContent = data.user.displayName || "User";
                }
                var bioEl = document.getElementById("profile-bio-summary");
                if (bioEl && typeof data.user.bio === "string") {
                  var bioText = data.user.bio.trim();
                  bioEl.textContent = bioText || "No bio yet — open Edit Profile to write one.";
                  bioEl.classList.toggle("profile-bio-empty", !bioText);
                }
                var headerName = document.querySelector(".profile-trigger .profile-name");
                var headerAvatar = document.querySelector(".profile-trigger .profile-avatar");
                if (headerName) headerName.textContent = data.user.displayName || "User";
                if (headerAvatar && data.user.imageUrl) headerAvatar.src = data.user.imageUrl;

                message.hidden = false;
                message.className = "message message-success";
                message.textContent = data.message || "Profile updated successfully.";
                form.style.display = "none";
                toggleButton.textContent = "Edit Profile";
                if (submitButton) {
                  submitButton.disabled = false;
                  submitButton.textContent = originalSubmitText;
                }
              } catch (error) {
                message.hidden = false;
                message.className = "message message-error";
                message.textContent = "Update failed: " + (error && error.message ? error.message : "Unknown error");
                if (submitButton) {
                  submitButton.disabled = false;
                  submitButton.textContent = originalSubmitText;
                }
              }
            });
          })();
        </script>
      </section>
    </main>
  </body>
</html>
